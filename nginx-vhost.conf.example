# Host nginx virtual host for flatforge.org
# Drop this file into /etc/nginx/sites-available/flatforge.org
# and symlink: ln -s /etc/nginx/sites-available/flatforge.org /etc/nginx/sites-enabled/
#
# Assumes:
#   - Cloudflare terminates TLS (origin receives plain HTTP on port 80)
#   - Docker Flatforge nginx listens on 127.0.0.1:8080 (set in .env)
#   - certbot / Let's Encrypt is NOT needed when Cloudflare handles TLS
#     (if you want origin cert too, add ssl block and use certbot normally)

upstream flatforge_backend {
    server 127.0.0.1:8080;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name flatforge.org www.flatforge.org;

    # Cloudflare sends real client IP in this header
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    real_ip_header CF-Connecting-IP;

    # Optional: restrict to Cloudflare IPs only (uncomment to harden)
    # allow 103.21.244.0/22;
    # ... (add all CF ranges above)
    # deny all;

    location / {
        proxy_pass         http://flatforge_backend;
        proxy_http_version 1.1;
        proxy_set_header   Connection        "";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        proxy_read_timeout  60s;
        proxy_send_timeout  60s;
        proxy_connect_timeout 10s;

        # Pass large OSTree objects without buffering
        proxy_buffering    off;
        proxy_max_temp_file_size 0;
    }

    # Health check accessible from host without going through Cloudflare
    location = /healthz {
        proxy_pass http://flatforge_backend/healthz;
        access_log off;
    }

    access_log /var/log/nginx/flatforge.access.log;
    error_log  /var/log/nginx/flatforge.error.log;
}
