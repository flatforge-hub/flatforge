{
  "app-id": "org.example.SampleApp",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sampleapp",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "name": "sampleapp",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 sampleapp.sh /app/bin/sampleapp"
      ],
      "sources": [
        {
          "type": "script",
          "dest-filename": "sampleapp.sh",
          "commands": [
            "echo 'Hello from Flatforge SampleApp'"
          ]
        }
      ]
    }
  ]
}
