# === Domain ===
DOMAIN=flatforge.org
VITE_DOMAIN=flatforge.org

# === nginx listen address ===
# Behind a host reverse proxy (recommended): bind only to localhost
LISTEN_ADDR=127.0.0.1
HTTP_PORT=8080
# Standalone (no host nginx): uncomment below instead
# LISTEN_ADDR=0.0.0.0
# HTTP_PORT=80

# === GPG signing ===
# Fill in after running: docker compose --profile init run --rm gpg-init
GPG_KEY_ID=
GPG_KEY_EMAIL=repo@flatforge.org
GPG_KEY_NAME=Flatforge Repository

# === OSTree repository ===
REPO_DEFAULT_BRANCH=stable
REPO_TITLE=Flatforge
REPO_DESCRIPTION=Open source Flatpak repository

# === Container user (rootless safety) ===
UID=1000
GID=1000
